# TriageAI Environment Variables
# Copy this to .env and fill in production values

# Flask
FLASK_ENV=development
JWT_SECRET_KEY=change-this-to-a-random-64-char-string
DATABASE_URL=postgresql://triageai_user:triageai_password@localhost:5432/triageai

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000

# PostgreSQL (Docker)
POSTGRES_DB=triageai
POSTGRES_USER=triageai_user
POSTGRES_PASSWORD=triageai_password
